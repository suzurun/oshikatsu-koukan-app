# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Edge Functionsのみ使用（公開禁止）

# ============================================================
# Expo (Mobile) - EXPO_PUBLIC_ prefix で自動公開
# ============================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================================
# Stripe
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx          # サーバーサイドのみ（公開禁止）
STRIPE_WEBHOOK_SECRET=whsec_xxxxx        # Webhookシークレット

# ============================================================
# AI APIs（Edge Functions内でのみ使用・公開禁止）
# ============================================================
GOOGLE_VISION_API_KEY=your-google-vision-key
XIMILAR_API_KEY=your-ximilar-key
ANTHROPIC_API_KEY=your-anthropic-key     # Claude API（価格分析・需要予測）

# ============================================================
# eKYC
# ============================================================
TRUSTDOCK_API_KEY=your-trustdock-key
TRUSTDOCK_WEBHOOK_SECRET=your-trustdock-webhook-secret

# ============================================================
# Expo EAS（ストア申請用）
# ============================================================
APPLE_ID=admin@oshikatsu.jp
APPLE_APP_STORE_APP_ID=your-app-store-connect-app-id
APPLE_TEAM_ID=your-apple-team-id
