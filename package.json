{
  "name": "oshikatsu-koukan-app",
  "version": "1.0.0",
  "description": "推し活×AI C2Cプラットフォーム モノレポ",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
